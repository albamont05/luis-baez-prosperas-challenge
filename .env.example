# --- App Configuration ---
APP_ENV=development
DEBUG=True
PROJECT_NAME="Prosperas Report System"

# --- Database ---
POSTGRES_USER=prosperas_user
POSTGRES_PASSWORD=prosperas_pass
POSTGRES_DB=reports_db
# URL usada internamente por la API
DATABASE_URL=postgresql+asyncpg://prosperas_user:prosperas_pass@postgres:5432/reports_db

# --- AWS / LocalStack ---
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_PUBLIC_IP=your_public_ip_here

# --- SQS / S3 Config ---
SQS_QUEUE_NAME=reports-queue
S3_BUCKET_NAME=prosperas-reports-bucket
