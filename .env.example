# --- Configuración de la App ---
APP_ENV=development  # development | production
DEBUG=True
PROJECT_NAME="Prosperas Report System"

# --- Seguridad ---
SECRET_KEY=tu_secret_key_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AWS / LocalStack ---
# En LocalStack, usa: http://localhost:4566
# En Producción, deja que Boto3 use el endpoint por defecto (vacío)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Recursos Específicos ---
SQS_QUEUE_NAME=reports-queue
S3_BUCKET_NAME=prosperas-reports-bucket

# --- Base de Datos (RDS / Local) ---
# Cambiar por la URL real en producción
DATABASE_URL=postgresql://user:pass@localhost:5432/reports_db